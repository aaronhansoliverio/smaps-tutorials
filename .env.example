# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web App → Config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated list of emails that are automatically assigned the "admin" role on first login.
# Add your own email here so you can manage all other users.
VITE_ADMIN_EMAILS=your@email.com
